{
    "mcpServers": {
        "powerbi-modeling-mcp": {
            "type": "stdio",
            "command": "cmd",
            "args": [
                "/c",
                "npx",
                "-y",
                "@microsoft/powerbi-modeling-mcp@latest",
                "--start"
            ]
        },
        "powerbi-remote-mcp": {
            "type": "http",
            "url": "https://api.fabric.microsoft.com/v1/mcp/powerbi"
        },
        "microsoft-fabric-mcp": {
            "type": "stdio",
            "command": "cmd",
            "args": [
                "/c",
                "npx",
                "-y",
                "@microsoft/fabric-mcp@latest",
                "server",
                "start",
                "--mode",
                "all"
            ]
        },
        "microsoft-learn-mcp": {
            "type": "http",
            "url": "https://learn.microsoft.com/api/mcp"
        },
        "github-mcp": {
            "command": "docker",
            "args": [
                "mcp",
                "gateway",
                "run",
                "--servers",
                "github-official"
            ],
            "env": {
                "LOCALAPPDATA": "C:\\Users\\<USER>\\AppData\\Local",
                "ProgramData": "C:\\ProgramData",
                "ProgramFiles": "C:\\Program Files"
            }
        },
        "azure-mcp": {
            "command": "docker",
            "args": [
                "mcp",
                "gateway",
                "run",
                "--servers",
                "azure"
            ],
            "env": {
                "LOCALAPPDATA": "C:\\Users\\<USER>\\AppData\\Local",
                "ProgramData": "C:\\ProgramData",
                "ProgramFiles": "C:\\Program Files"
            }
        },
        "dockerhub-mcp": {
            "command": "docker",
            "args": [
                "mcp",
                "gateway",
                "run",
                "--servers",
                "dockerhub"
            ],
            "env": {
                "LOCALAPPDATA": "C:\\Users\\<USER>\\AppData\\Local",
                "ProgramData": "C:\\ProgramData",
                "ProgramFiles": "C:\\Program Files"
            }
        }
    }
}
